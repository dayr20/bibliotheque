{% extends 'base.html.twig' %}

{% block title %}Modifier le chapitre {{ chapter.number }} - {{ chapter.manga.title }} - MangaZone{% endblock %}

{% block body %}
<div class="container py-4">
    <h1>Modifier le chapitre {{ chapter.number }} de {{ chapter.manga.title }}</h1>

    <form method="post" class="mt-4">
        <div class="mb-3">
            <label for="title" class="form-label">Titre du chapitre</label>
            <input type="text" class="form-control" id="title" name="title" required value="{{ chapter.title }}">
        </div>

        <div class="mb-3">
            <label for="number" class="form-label">Numéro du chapitre</label>
            <input type="number" class="form-control" id="number" name="number" required min="1" step="1" value="{{ chapter.number }}">
        </div>

        <div class="mb-3">
            <label for="content" class="form-label">Contenu du chapitre</label>
            <textarea class="form-control" id="content" name="content" rows="15" required>{{ chapter.content }}</textarea>
            <small class="text-muted">Vous pouvez utiliser le format Markdown pour le contenu.</small>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-2"></i>Enregistrer les modifications
            </button>
            <a href="{{ path('app_manga_chapters', {'id': chapter.manga.id}) }}" class="btn btn-outline-secondary">
                <i class="fas fa-times me-2"></i>Annuler
            </a>
        </div>
    </form>
</div>

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Ajouter une confirmation avant de quitter la page si des modifications ont été faites
    let form = document.querySelector('form');
    let initialFormState = form.innerHTML;
    
    window.addEventListener('beforeunload', function(e) {
        if (form.innerHTML !== initialFormState) {
            e.preventDefault();
            e.returnValue = '';
        }
    });
});
</script>
{% endblock %}
{% endblock %} 