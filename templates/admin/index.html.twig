{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Tableau de bord d'administration</h1>
    
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Utilisateurs</h5>
                    <p class="card-text">Gérer les utilisateurs de l'application</p>
                    <a href="{{ path('admin_users_index') }}" class="btn btn-primary">Voir les utilisateurs</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Mangas</h5>
                    <p class="card-text">Gérer les mangas et leurs chapitres</p>
                    <a href="#" class="btn btn-primary">Gérer les mangas</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Statistiques</h5>
                    <p class="card-text">Voir les statistiques de l'application</p>
                    <a href="#" class="btn btn-primary">Voir les stats</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %} 