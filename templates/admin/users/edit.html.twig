{% extends 'base.html.twig' %}

{% block title %}Modifier les rôles - {{ user.email }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title mb-0">Modifier les rôles de {{ user.email }}</h2>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="mb-4">
                            {% for label, role in available_roles %}
                                <div class="form-check">
                                    <input type="checkbox" 
                                           class="form-check-input" 
                                           id="role_{{ role }}" 
                                           name="roles[]" 
                                           value="{{ role }}"
                                           {% if role in user.roles %}checked{% endif %}>
                                    <label class="form-check-label" for="role_{{ role }}">
                                        {{ label }}
                                    </label>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('admin_users_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Retour
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %} 