{% extends 'base.html.twig' %}

{% block title %}Mes Notifications{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-bell"></i> Mes Notifications</h1>
        {% if notifications|length > 0 %}
            <form action="{{ path('app_notifications_read_all') }}" method="post">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fas fa-check-double"></i> Tout marquer comme lu
                </button>
            </form>
        {% endif %}
    </div>

    {% if notifications|length > 0 %}
        <div class="list-group">
            {% for notif in notifications %}
                <div class="list-group-item list-group-item-action {% if not notif.isRead %}list-group-item-light border-start border-4 border-primary{% endif %}">
                    <div class="d-flex w-100 justify-content-between align-items-start">
                        <div class="d-flex align-items-start gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; background: var(--bg-card, #16213e);">
                                <i class="{{ notif.typeIcon }} text-{{ notif.typeColor }}"></i>
                            </div>
                            <div>
                                <h5 class="mb-1">
                                    {{ notif.title }}
                                    {% if not notif.isRead %}
                                        <span class="badge bg-primary ms-1">Nouveau</span>
                                    {% endif %}
                                </h5>
                                <p class="mb-1">{{ notif.message }}</p>
                                <small class="text-muted">
                                    <i class="fas fa-clock"></i> {{ notif.createdAt|date('d/m/Y à H:i') }}
                                    &bull; <span class="badge bg-{{ notif.typeColor }}">{{ notif.typeLabel }}</span>
                                </small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            {% if notif.link %}
                                <form action="{{ path('app_notification_read', {'id': notif.id}) }}" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-primary" title="Voir">
                                        <i class="fas fa-external-link-alt"></i>
                                    </button>
                                </form>
                            {% elseif not notif.isRead %}
                                <form action="{{ path('app_notification_read', {'id': notif.id}) }}" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Marquer comme lu">
                                        <i class="fas fa-check"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="fas fa-bell-slash fa-4x text-muted mb-3"></i>
            <h3 class="text-muted">Aucune notification</h3>
            <p class="text-muted">Vous n'avez pas encore de notifications.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
