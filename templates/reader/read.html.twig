{% extends 'base.html.twig' %}

{% block title %}Lecture de {{ manga.title }} - Chapitre {{ currentChapter.number }} - MangaZone{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4 rounded shadow-sm">
                <div class="container-fluid">
                    <a class="navbar-brand" href="{{ path('app_manga_show', {'id': manga.id}) }}">
                        <i class="fas fa-arrow-left me-2"></i>{{ manga.title }}
                    </a>
                    <div class="d-flex gap-2">
                        <a href="{{ prevChapter ? path('app_manga_read', {'id': manga.id, 'chapter': prevChapter.id}) : '#' }}" 
                           class="btn btn-outline-secondary {{ not prevChapter ? 'disabled' : '' }}">
                            <i class="fas fa-chevron-left"></i> Chapitre précédent
                        </a>
                        <select class="form-select" id="chapterSelect" onchange="window.location.href=this.value">
                            {% for chapter in chapters %}
                                <option value="{{ path('app_manga_read', {'id': manga.id, 'chapter': chapter.id}) }}"
                                        {{ chapter.id == currentChapter.id ? 'selected' : '' }}>
                                    Chapitre {{ chapter.number }} - {{ chapter.title }}
                                </option>
                            {% endfor %}
                        </select>
                        <a href="{{ nextChapter ? path('app_manga_read', {'id': manga.id, 'chapter': nextChapter.id}) : '#' }}"
                           class="btn btn-outline-secondary {{ not nextChapter ? 'disabled' : '' }}">
                            Chapitre suivant <i class="fas fa-chevron-right"></i>
                        </a>
                    </div>
                </div>
            </nav>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow">
                <div class="card-header">
                    <h2 class="card-title h5 mb-0">
                        Chapitre {{ currentChapter.number }} - {{ currentChapter.title }}
                    </h2>
                </div>
                <div class="card-body chapter-content">
                    {{ currentChapter.content|nl2br }}
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                {% if prevChapter %}
                    <a href="{{ path('app_manga_read', {'id': manga.id, 'chapter': prevChapter.id}) }}"
                       class="btn btn-outline-primary">
                        <i class="fas fa-chevron-left me-2"></i>
                        Chapitre {{ prevChapter.number }}
                    </a>
                {% else %}
                    <div></div>
                {% endif %}

                {% if nextChapter %}
                    <a href="{{ path('app_manga_read', {'id': manga.id, 'chapter': nextChapter.id}) }}"
                       class="btn btn-outline-primary">
                        Chapitre {{ nextChapter.number }}
                        <i class="fas fa-chevron-right ms-2"></i>
                    </a>
                {% else %}
                    <div></div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% block stylesheets %}
{{ parent() }}
<style>
.chapter-content {
    font-size: 1.1rem;
    line-height: 1.8;
    text-align: justify;
}

.navbar {
    position: sticky;
    top: 0;
    z-index: 1000;
}

@media (max-width: 768px) {
    .navbar .btn {
        padding: 0.375rem;
    }
    .navbar .btn i {
        margin: 0;
    }
    .navbar .btn span {
        display: none;
    }
}
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Gérer les raccourcis clavier pour la navigation
    document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
            const link = e.key === 'ArrowLeft' 
                ? document.querySelector('a[href*="chapter"][href!="#"]:first-of-type')
                : document.querySelector('a[href*="chapter"][href!="#"]:last-of-type');
            
            if (link && !link.classList.contains('disabled')) {
                window.location.href = link.href;
            }
        }
    });
});
</script>
{% endblock %}
{% endblock %} 