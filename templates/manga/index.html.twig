{% extends 'base.html.twig' %}

{% block title %}Liste des Mangas{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-book-open"></i> Liste des Mangas</h1>
        {% if can_edit %}
            <a href="{{ path('app_manga_new') }}" class="btn btn-success">
                <i class="fas fa-plus"></i> Ajouter un manga
            </a>
        {% endif %}
    </div>

    {# Recherche avancée #}
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#advancedSearch" style="cursor: pointer;">
            <h5 class="mb-0"><i class="fas fa-search"></i> Recherche avancée</h5>
            <i class="fas fa-chevron-down"></i>
        </div>
        <div class="collapse show" id="advancedSearch">
            <div class="card-body">
                <form method="GET" id="searchForm">
                    <div class="row g-3">
                        {# Ligne 1 : Titre + Auteur #}
                        <div class="col-md-5">
                            <label for="title" class="form-label">Titre</label>
                            <input type="text" name="title" id="title" class="form-control" placeholder="Rechercher par titre..." value="{{ search.title|default('') }}">
                        </div>
                        <div class="col-md-5">
                            <label for="author" class="form-label">Auteur</label>
                            <input type="text" name="author" id="author" class="form-control" placeholder="Rechercher par auteur..." value="{{ search.author|default('') }}">
                        </div>
                        <div class="col-md-2">
                            <label for="rating_min" class="form-label">Note min.</label>
                            <select name="rating_min" id="rating_min" class="form-select">
                                <option value="">Toutes</option>
                                {% for i in 1..5 %}
                                    <option value="{{ i }}" {% if search.rating_min|default('') == i|string %}selected{% endif %}>
                                        {{ i }}+ {{ '★'|repeat(i) }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        {# Ligne 2 : Genre + Statut + Année + Tri #}
                        <div class="col-md-3">
                            <label for="genre" class="form-label">Genre</label>
                            <select name="genre" id="genre" class="form-select">
                                <option value="">Tous les genres</option>
                                {% for genre in genres|default([]) %}
                                    <option value="{{ genre.name }}" {% if search.genre|default('') == genre.name %}selected{% endif %}>{{ genre.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="status" class="form-label">Statut</label>
                            <select name="status" id="status" class="form-select">
                                <option value="">Tous les statuts</option>
                                <option value="ongoing" {% if search.status|default('') == 'ongoing' %}selected{% endif %}>En cours</option>
                                <option value="completed" {% if search.status|default('') == 'completed' %}selected{% endif %}>Terminé</option>
                                <option value="hiatus" {% if search.status|default('') == 'hiatus' %}selected{% endif %}>En pause</option>
                                <option value="cancelled" {% if search.status|default('') == 'cancelled' %}selected{% endif %}>Annulé</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="year" class="form-label">Année</label>
                            <select name="year" id="year" class="form-select">
                                <option value="">Toutes</option>
                                {% for y in years|default([]) %}
                                    <option value="{{ y }}" {% if search.year|default('') == y|string %}selected{% endif %}>{{ y }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="sort" class="form-label">Trier par</label>
                            <select name="sort" id="sort" class="form-select">
                                <option value="rating" {% if search.sort|default('rating') == 'rating' %}selected{% endif %}>Note</option>
                                <option value="title" {% if search.sort|default('') == 'title' %}selected{% endif %}>Titre</option>
                                <option value="year" {% if search.sort|default('') == 'year' %}selected{% endif %}>Année</option>
                                <option value="newest" {% if search.sort|default('') == 'newest' %}selected{% endif %}>Nouveautés</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-primary flex-grow-1">
                                <i class="fas fa-search"></i> Rechercher
                            </button>
                            <a href="{{ path('app_manga_index') }}" class="btn btn-outline-secondary" title="Réinitialiser">
                                <i class="fas fa-times"></i>
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Résultats #}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <p class="text-muted mb-0">{{ mangas|length }} manga{{ mangas|length > 1 ? 's' : '' }} trouvé{{ mangas|length > 1 ? 's' : '' }}</p>
    </div>

    {# Liste des mangas #}
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" id="manga-grid">
        {% for manga in mangas %}
            <div class="col manga-item">
                <div class="card h-100">
                    {% if manga.coverImage %}
                        <img src="{{ manga.coverImage }}" class="card-img-top" alt="{{ manga.title }}" loading="lazy">
                    {% else %}
                        <div class="card-img-top bg-light text-center py-5">
                            <i class="fas fa-book fa-3x text-muted"></i>
                        </div>
                    {% endif %}
                    <div class="card-body">
                        <h5 class="card-title">{{ manga.title }}</h5>
                        <h6 class="card-subtitle mb-2 text-muted">{{ manga.author }}</h6>
                        <p class="card-text">{{ manga.description|default('')|slice(0, 100) }}{% if manga.description|default('')|length > 100 %}...{% endif %}</p>

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="rating">
                                {% for i in 1..5 %}
                                    {% if i <= manga.rating %}
                                        <i class="fas fa-star text-warning"></i>
                                    {% else %}
                                        <i class="far fa-star text-warning"></i>
                                    {% endif %}
                                {% endfor %}
                            </div>
                            <div>
                                {% if manga.isNew %}
                                    <span class="badge bg-success">Nouveau</span>
                                {% endif %}
                                {% if manga.status %}
                                    <span class="badge bg-info">{{ manga.status }}</span>
                                {% endif %}
                            </div>
                        </div>

                        {% if manga.year %}
                            <small class="text-muted"><i class="fas fa-calendar"></i> {{ manga.year }}</small>
                        {% endif %}
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100">
                            <a href="{{ path('app_manga_show', {'id': manga.id}) }}" class="btn btn-outline-primary">
                                <i class="fas fa-eye"></i> Voir
                            </a>
                            {% if can_edit %}
                                <a href="{{ path('app_manga_edit', {'id': manga.id}) }}" class="btn btn-outline-secondary">
                                    <i class="fas fa-edit"></i> Éditer
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="fas fa-search fa-3x mb-3"></i>
                    <h4>Aucun résultat</h4>
                    <p>Aucun manga ne correspond à vos critères de recherche.</p>
                    <a href="{{ path('app_manga_index') }}" class="btn btn-primary">
                        <i class="fas fa-undo"></i> Réinitialiser les filtres
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.card-img-top {
    height: 300px;
    object-fit: cover;
}
</style>
{% endblock %}
