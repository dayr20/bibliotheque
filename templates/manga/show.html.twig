{% extends 'base.html.twig' %}

{% block title %}{{ manga.title }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_manga_index') }}">Mangas</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ manga.title }}</li>
        </ol>
    </nav>

    <div class="card">
        <div class="row g-0">
            <div class="col-md-4">
                {% if manga.coverImage %}
                    <img src="{{ manga.coverImage }}" class="img-fluid rounded-start manga-cover" alt="{{ manga.title }}">
                {% else %}
                    <div class="bg-light text-center py-5">
                        <i class="fas fa-book fa-5x text-muted"></i>
                    </div>
                {% endif %}
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <h1 class="card-title">{{ manga.title }}</h1>
                        {% if manga.isNew %}
                            <span class="badge bg-success">Nouveau</span>
                        {% endif %}
                    </div>
                    
                    <h3 class="card-subtitle mb-3 text-muted">par {{ manga.author }}</h3>
                    
                    <div class="rating mb-3">
                        <span class="me-2">Note :</span>
                        {% for i in 1..5 %}
                            {% if i <= manga.rating %}
                                <i class="fas fa-star text-warning"></i>
                            {% else %}
                                <i class="far fa-star text-warning"></i>
                            {% endif %}
                        {% endfor %}
                        <span class="ms-2">({{ manga.rating }}/5)</span>
                    </div>

                    <h4>Description</h4>
                    <p class="card-text">{{ manga.description }}</p>

                    {% if manga.genres|length > 0 %}
                        <h4>Genres</h4>
                        <div class="mb-3">
                            {% for genre in manga.genres %}
                                <span class="badge bg-primary me-1">{{ genre.name }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {% if can_edit %}
                        <div class="mt-4">
                            <a href="{{ path('app_manga_edit', {'id': manga.id}) }}" class="btn btn-primary me-2">
                                <i class="fas fa-edit"></i> Modifier
                            </a>
                            <form action="{{ path('app_manga_delete', {'id': manga.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce manga ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ manga.id) }}">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-trash"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.manga-cover {
    width: 100%;
    height: 500px;
    object-fit: cover;
}
</style>
{% endblock %}
