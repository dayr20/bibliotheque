{% extends 'base.html.twig' %}

{% block title %}Paramètres du profil{% endblock %}

{% block body %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_profile') }}">Mon Profil</a></li>
            <li class="breadcrumb-item active">Paramètres</li>
        </ol>
    </nav>

    <h1 class="mb-4"><i class="fas fa-cog"></i> Paramètres du profil</h1>

    <div class="row">
        {# Avatar #}
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-camera"></i> Photo de profil</h5>
                </div>
                <div class="card-body text-center">
                    <div class="mb-3">
                        {% if user.avatarFilename %}
                            <img src="/uploads/avatars/{{ user.avatarFilename }}" alt="Avatar"
                                class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;">
                        {% else %}
                            <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center"
                                style="width: 150px; height: 150px; background: var(--bg-card, #16213e); font-size: 3rem;">
                                <i class="fas fa-user text-muted"></i>
                            </div>
                        {% endif %}
                    </div>

                    <form action="{{ path('app_profile_settings') }}" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <input type="file" class="form-control" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp">
                            <div class="form-text">JPG, PNG, GIF ou WebP. Max 2 Mo.</div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="fas fa-upload"></i> Changer la photo
                        </button>
                    </form>

                    {% if user.avatarFilename %}
                        <hr>
                        <form action="{{ path('app_profile_avatar_delete') }}" method="post">
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                onclick="return confirm('Supprimer votre avatar ?');">
                                <i class="fas fa-trash"></i> Supprimer la photo
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Informations du profil #}
        <div class="col-md-8 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-user-edit"></i> Informations</h5>
                </div>
                <div class="card-body">
                    <form action="{{ path('app_profile_settings') }}" method="post">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" value="{{ user.email }}" disabled>
                            <div class="form-text">L'email ne peut pas être modifié.</div>
                        </div>

                        <div class="mb-3">
                            <label for="display_name" class="form-label">Nom d'affichage</label>
                            <input type="text" class="form-control" id="display_name" name="display_name"
                                value="{{ user.displayName|default('') }}" placeholder="Votre pseudo..."
                                maxlength="50">
                            <div class="form-text">Ce nom sera affiché à la place de votre email.</div>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Enregistrer
                        </button>
                    </form>
                </div>
            </div>

            {# Infos compte #}
            <div class="card mt-3">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-shield-alt"></i> Sécurité</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <p class="text-muted mb-1">Statut du compte</p>
                            <p>
                                {% if user.isVerified %}
                                    <span class="badge bg-success"><i class="fas fa-check"></i> Vérifié</span>
                                {% else %}
                                    <span class="badge bg-warning"><i class="fas fa-exclamation-triangle"></i> Non vérifié</span>
                                {% endif %}
                            </p>
                        </div>
                        <div class="col-6">
                            <p class="text-muted mb-1">Rôle</p>
                            <p>
                                {% for role in user.roles %}
                                    <span class="badge bg-{% if role == 'ROLE_ADMIN' %}danger{% elseif role == 'ROLE_SUPER_ADMIN' %}dark{% else %}primary{% endif %}">
                                        {{ role }}
                                    </span>
                                {% endfor %}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
