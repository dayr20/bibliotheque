{% extends 'base.html.twig' %}

{% block title %}{{ statusLabel }} - Mon profil{% endblock %}

{% block body %}
<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_profile') }}">Mon profil</a></li>
            <li class="breadcrumb-item active">{{ statusLabel }}</li>
        </ol>
    </nav>

    <h2 class="mb-4">{{ statusLabel }}</h2>

    {# Navigation entre statuts #}
    <ul class="nav nav-pills mb-4">
        {% for key, label in statuses %}
            <li class="nav-item">
                <a class="nav-link {% if key == currentStatus %}active{% endif %}" href="{{ path('app_profile_list', {'status': key}) }}">
                    {{ label }}
                    <span class="badge bg-secondary ms-1">{{ statusCounts[key] ?? 0 }}</span>
                </a>
            </li>
        {% endfor %}
    </ul>

    {% if entries|length > 0 %}
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
            {% for entry in entries %}
                <div class="col">
                    <div class="card manga-card h-100">
                        <div class="position-relative">
                            {% if entry.manga.coverImage %}
                                <img src="{{ entry.manga.coverImage }}" class="card-img-top" alt="{{ entry.manga.title }}" style="height: 280px; object-fit: cover;">
                            {% else %}
                                <div class="card-img-top bg-dark d-flex align-items-center justify-content-center" style="height: 280px;">
                                    <i class="fas fa-book fa-3x text-muted"></i>
                                </div>
                            {% endif %}
                        </div>
                        <div class="card-body">
                            <h6 class="card-title text-truncate">{{ entry.manga.title }}</h6>
                            <p class="small text-muted mb-2">{{ entry.manga.author }}</p>
                            <small class="text-muted">Ajouté le {{ entry.addedAt|date('d/m/Y') }}</small>
                        </div>
                        <div class="card-footer">
                            <a href="{{ path('app_manga_show', {'id': entry.manga.id}) }}" class="btn btn-sm btn-outline-primary w-100">
                                <i class="fas fa-eye me-1"></i>Voir
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            Aucun manga dans cette liste.
            <a href="{{ path('app_manga_index') }}">Parcourir le catalogue</a>
        </div>
    {% endif %}
</div>
{% endblock %}
