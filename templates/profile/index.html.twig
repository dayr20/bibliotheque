{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .manga-card {
        transition: all 0.3s ease;
        height: 100%;
    }
    .manga-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    .manga-cover {
        height: 300px;
        object-fit: cover;
        border-radius: 8px 8px 0 0;
    }
    .favorite-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .favorite-btn:hover {
        transform: scale(1.1);
    }
    .favorite-btn.active {
        color: #dc3545;
    }
</style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row mb-4">
        <div class="col">
            <h1>Mon profil</h1>
            <p class="text-muted">{{ user.email }}</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h2 class="card-title mb-4">Mes mangas favoris</h2>
            
            {% if user.favoriteMangas|length > 0 %}
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    {% for manga in user.favoriteMangas %}
                        <div class="col">
                            <div class="card manga-card h-100 position-relative">
                                {% if manga.coverImage %}
                                    <img src="{{ manga.coverImage }}" class="manga-cover" alt="{{ manga.title }}">
                                {% else %}
                                    <div class="manga-cover bg-light d-flex align-items-center justify-content-center">
                                        <i class="fas fa-book fa-3x text-muted"></i>
                                    </div>
                                {% endif %}
                                
                                <button class="favorite-btn active" 
                                        onclick="toggleFavorite(this, '{{ manga.id }}')"
                                        title="Retirer des favoris">
                                    <i class="fas fa-heart"></i>
                                </button>

                                <div class="card-body">
                                    <h5 class="card-title">{{ manga.title }}</h5>
                                    <p class="card-text text-muted">{{ manga.author }}</p>
                                    <p class="card-text">{{ manga.description|slice(0, 150) }}...</p>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    Vous n'avez pas encore de mangas favoris.
                    <a href="{{ path('app_manga_index') }}" class="alert-link">Parcourir les mangas</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function toggleFavorite(button, mangaId) {
    fetch(`/profile/manga/${mangaId}/toggle-favorite`, {
        method: 'POST',
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            if (!data.isFavorite) {
                // Si le manga n'est plus en favori, on supprime la carte
                button.closest('.col').remove();
                
                // Si c'était le dernier manga favori, on affiche le message
                const mangaCards = document.querySelectorAll('.manga-card');
                if (mangaCards.length === 0) {
                    const container = document.querySelector('.card-body');
                    container.innerHTML = `
                        <h2 class="card-title mb-4">Mes mangas favoris</h2>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            Vous n'avez pas encore de mangas favoris.
                            <a href="{{ path('app_manga_index') }}" class="alert-link">Parcourir les mangas</a>
                        </div>
                    `;
                }
            }
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Une erreur est survenue lors de la mise à jour des favoris.');
    });
}
</script>
{% endblock %} 